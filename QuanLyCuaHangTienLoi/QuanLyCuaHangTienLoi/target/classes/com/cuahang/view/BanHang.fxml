<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cuahang.view.BanHangController">
   <children>
      <AnchorPane prefHeight="400.0" prefWidth="600.0">
         <children>
            <TableView fx:id="tblSanPham" layoutY="77.0" onMouseClicked="#xuLyChonSanPham" prefHeight="200.0" prefWidth="320.0">
              <columns>
                <TableColumn fx:id="colMaSP" prefWidth="75.0" text="Mã SP" />
                <TableColumn fx:id="colTenSP" prefWidth="100.0" text="Tên SP" />
                  <TableColumn fx:id="colGiaBan" prefWidth="75.0" text="Giá Bán" />
                  <TableColumn fx:id="colTonKho" prefWidth="75.0" text="Tồn Kho" />
              </columns>
            </TableView>
            <TableView fx:id="tblGioHang" layoutX="346.0" layoutY="77.0" onMouseClicked="#xuLyGiamSoLuong" prefHeight="200.0" prefWidth="253.0">
               <columns>
                  <TableColumn fx:id="colTenSPGio" prefWidth="100.0" text="Tên SP" />
                  <TableColumn fx:id="colSoLuongGio" prefWidth="75.0" text="Số Lượng" />
                  <TableColumn fx:id="colThanhTienGio" prefWidth="75.0" text="Thành Tiền" />
               </columns>
            </TableView>
            <Label layoutX="320.0" layoutY="287.0" text="Tổng tiền" />
            <Label layoutX="318.0" layoutY="314.0" text="Khách đưa" />
            <Label layoutX="321.0" layoutY="341.0" text="Tiền thừa" />
            <TextField fx:id="txtTongTien" layoutX="383.0" layoutY="283.0" />
            <TextField fx:id="txtKhachDua" layoutX="384.0" layoutY="310.0" />
            <TextField fx:id="txtTienThua" layoutX="384.0" layoutY="337.0" />
            <Button fx:id="btnThanhToan" layoutX="420.0" layoutY="363.0" mnemonicParsing="false" onAction="#xuLyThanhToan" text="Thanh toán" />
            <Button layoutX="14.0" layoutY="41.0" mnemonicParsing="false" onAction="#moCuaSoQuanLySP" text="Cập Nhật SP" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
