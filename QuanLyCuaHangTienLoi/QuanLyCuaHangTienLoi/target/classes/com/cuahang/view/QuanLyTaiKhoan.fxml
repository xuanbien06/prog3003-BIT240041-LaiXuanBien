<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cuahang.view.QuanLyTaiKhoanController">
   <children>
      <TableView fx:id="tblTaiKhoan" onMouseClicked="#xuLyClickBang" prefHeight="200.0" prefWidth="600.0">
        <columns>
          <TableColumn fx:id="colMaNV" prefWidth="85.0" text="Mã NV" />
          <TableColumn fx:id="colTenNV" prefWidth="140.0" text="Tên NV" />
            <TableColumn fx:id="colTaiKhoan" prefWidth="125.0" text="Tài Khoản" />
            <TableColumn fx:id="colMatKhau" prefWidth="125.0" text="Mật Khẩu" />
            <TableColumn fx:id="colVaiTro" prefWidth="125.0" text="Vai Trò" />
        </columns>
      </TableView>
      <TextField fx:id="txtMaNV" layoutX="45.0" layoutY="202.0" prefHeight="26.0" prefWidth="216.0" />
      <TextField fx:id="txtTenNV" layoutX="45.0" layoutY="243.0" prefHeight="26.0" prefWidth="216.0" />
      <TextField fx:id="txtTaiKhoan" layoutX="45.0" layoutY="282.0" prefHeight="26.0" prefWidth="216.0" />
      <TextField fx:id="txtMatKhau" layoutX="45.0" layoutY="321.0" prefHeight="26.0" prefWidth="216.0" />
      <TextField fx:id="txtVaiTro" layoutX="45.0" layoutY="360.0" prefHeight="26.0" prefWidth="216.0" />
      <Button layoutX="330.0" layoutY="223.0" mnemonicParsing="false" onAction="#xuLyThem" text="Thêm" />
      <Button layoutX="449.0" layoutY="223.0" mnemonicParsing="false" onAction="#xuLySua" text="Sửa" />
      <Button layoutX="336.0" layoutY="298.0" mnemonicParsing="false" onAction="#xuLyXoa" text="Xóa" />
      <Button layoutX="449.0" layoutY="298.0" mnemonicParsing="false" onAction="#xuLyLamMoi" text="Làm Mới" />
   </children>
</AnchorPane>
